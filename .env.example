# JanVayu Environment Variables
# Copy this file to .env and fill in the values

# Resend (email digests)
RESEND_API_KEY=
RESEND_FROM=digest@janvayu.in

# Netlify
BLOB_TOKEN=
NETLIFY_SITE_ID=

# Groq AI — runs Llama 3.3 70B open-source LLM (free key at https://console.groq.com)
GROQ_API_KEY=

# Agent-Reach feed ingest — API key for GitHub Actions to push social media data
FEED_INGEST_KEY=

# Sarvam — Indian-language translation (auto-translates docs/ → docs-hi/bn/mr/ta/)
SARVAM_API_KEY=
